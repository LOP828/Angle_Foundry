# Environment values override config/config.toml when present.
ANGLE_FOUNDRY_API_KEY=your_api_key_here

# Optional runtime overrides for AI + Feishu delivery.
ANGLE_FOUNDRY_AI_BASE_URL=https://your-ai-base-url/v1
ANGLE_FOUNDRY_AI_MODEL=your-model-name
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook

# Optional numeric overrides.
ANGLE_FOUNDRY_AI_TIMEOUT_SECONDS=30
ANGLE_FOUNDRY_AI_MAX_RETRIES=1

# PowerShell example:
# $env:ANGLE_FOUNDRY_API_KEY = "your_api_key_here"
# $env:ANGLE_FOUNDRY_AI_BASE_URL = "https://your-ai-base-url/v1"
# $env:ANGLE_FOUNDRY_AI_MODEL = "your-model-name"
# $env:ANGLE_FOUNDRY_AI_TIMEOUT_SECONDS = "30"
# $env:ANGLE_FOUNDRY_AI_MAX_RETRIES = "1"
# $env:FEISHU_WEBHOOK = "https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook"
